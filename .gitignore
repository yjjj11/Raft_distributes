# 可执行文件输出目录（对应 CMAKE 的 EXECUTABLE_OUTPUT_PATH）
bin/
logs/
# 编译缓存/构建目录
build/
.cache/          # 若为隐藏目录则保留，否则改为 cache/
Asio_mrpc/       # 推荐：匹配普通目录 Asio_mrpc（无前置点）

# 补充：通用编译产物（可选，避免遗漏）
*.o              # 目标文件
*.so             # 动态库
*.a              # 静态库
compile_commands.json  # 编译数据库（若不需要提交）
.DS_Store        # macOS 隐藏文件
*.log            # 日志文件